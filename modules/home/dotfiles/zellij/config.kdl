// Zellij Configuration
// Mutable dotfile - changes apply immediately without restart

// UI
ui {
    pane_frames {
        rounded_corners true
        hide_session_name false
    }
    compact_bar true
}

// Keybinding mode: unlock first (Ctrl+g to unlock, avoids conflicts with Neovim Ctrl+p)
keybinds "unlock-first"

// Layout
default_layout "compact"
default_shell "zsh"

// Options
scroll_buffer_size 10000
copy_on_select true
mouse_mode true
